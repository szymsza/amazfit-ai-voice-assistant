{
  "name": "amazfit-voice-assistant-server",
  "version": "1.0.0",
  "description": "Node.js/TypeScript server for AI Voice Assistant",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "pm2:install": "npm install -g pm2",
    "pm2:setup": "pm2 startup && pm2 save",
    "pm2:start": "pm2 start npm --name amazfit-server -- start",
    "pm2:restart": "pm2 restart amazfit-server",
    "pm2:stop": "pm2 stop amazfit-server",
    "pm2:logs": "pm2 logs amazfit-server"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "opusscript": "^0.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
