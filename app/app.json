{
  "configVersion": "v3",
  "app": {
    "appId": 20001,
    "appName": "AI Voice Assistant",
    "appType": "app",
    "version": {
      "code": 1,
      "name": "1.0.0"
    },
    "icon": "icon.png",
    "vender": "zepp",
    "description": "AI Voice Assistant for Amazfit Balance"
  },
  "permissions": [
    "data:os.device.info",
    "device:os.local_storage",
    "device:os.mic"
  ],
  "runtime": {
    "apiVersion": {
      "compatible": "3.0",
      "target": "3.6",
      "minVersion": "3.0"
    }
  },
  "debug": false,
  "targets": {
    "gt": {
      "module": {
        "page": {
          "pages": ["page/gt/home/index.page"]
        },
        "app-side": {
          "path": "app-side/index"
        },
        "setting": {
          "path": "setting/index"
        }
      },
      "platforms": [
        {
          "st": "r"
        }
      ],
      "designWidth": 480
    }
  },
  "i18n": {
    "en-US": {
      "appName": "AI Voice Assistant"
    }
  },
  "defaultLanguage": "en-US"
}
